{%- unless section.settings.full_width -%}
  {%- render 'section-spacing-collapsing' -%}
{%- endunless -%}

<style>
  #shopify-section-{{ section.id }} {
    {%- if section.settings.full_width -%}
      --section-outer-spacing-block: 0;
    {%- endif -%}

    {%- if section.settings.allow_transparent_header -%}
      margin-block-start: calc(-1 * var(--header-height) * var(--section-is-first));
    {%- endif -%}
  }

  .image-overlay-slider-{{ section.id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .image-overlay-slider__track-{{ section.id }} {
    display: flex;
    width: 100%;
    transition: transform 0.6s ease;
    will-change: transform;
  }

  .image-overlay-slider__slide-{{ section.id }} {
    flex: 0 0 100%;
    min-width: 100%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .image-overlay-slider__nav-{{ section.id }} {
    position: absolute;
    left: 50%;
    bottom: 18px;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 20;
  }

  .image-overlay-slider__dot-{{ section.id }} {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: none;
    padding: 0;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.45);
  }

  .image-overlay-slider__dot-{{ section.id }}.is-active {
    background: rgba(255, 255, 255, 1);
  }

  .image-overlay-slider__arrow-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    background: rgba(0, 0, 0, 0.28);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
  }

  .image-overlay-slider__arrow--prev-{{ section.id }} {
    left: 16px;
  }

  .image-overlay-slider__arrow--next-{{ section.id }} {
    right: 16px;
  }

  @media screen and (max-width: 699px) {
    .image-overlay-slider__arrow-{{ section.id }} {
      width: 36px;
      height: 36px;
    }
  }
</style>

<div {% render 'section-properties' %} {% if section.settings.allow_transparent_header %}allow-transparent-header{% endif %}>
  {%- capture class -%}content-over-media content-over-media--{{ section.settings.image_size }} {% if section.settings.full_width %}full-bleed{% else %}shadow-block rounded-lg{% endif %}{%- endcapture -%}

  <div class="image-overlay-slider-{{ section.id }}" id="image-overlay-slider-{{ section.id }}">
    <div class="image-overlay-slider__track-{{ section.id }}">

      {%- for i in (1..3) -%}
        {%- liquid
          assign image_key = 'image_' | append: i
          assign mobile_image_key = 'mobile_image_' | append: i
          assign subheading_key = 'subheading_' | append: i
          assign heading_key = 'heading_' | append: i
          assign heading_tag_key = 'heading_tag_' | append: i
          assign content_key = 'content_' | append: i
          assign button_style_key = 'button_style_' | append: i
          assign button_size_key = 'button_size_' | append: i
          assign button_text_key = 'button_text_' | append: i
          assign button_url_key = 'button_url_' | append: i
          assign button_background_key = 'button_background_' | append: i
          assign button_text_color_key = 'button_text_color_' | append: i
          assign text_color_key = 'text_color_' | append: i
          assign overlay_color_key = 'overlay_color_' | append: i
          assign overlay_opacity_key = 'overlay_opacity_' | append: i

          assign slide_image = section.settings[image_key]
          assign slide_mobile_image = section.settings[mobile_image_key]
          assign slide_subheading = section.settings[subheading_key]
          assign slide_heading = section.settings[heading_key]
          assign slide_heading_tag = section.settings[heading_tag_key]
          assign slide_content = section.settings[content_key]
          assign slide_button_style = section.settings[button_style_key]
          assign slide_button_size = section.settings[button_size_key]
          assign slide_button_text = section.settings[button_text_key]
          assign slide_button_url = section.settings[button_url_key]
          assign slide_button_background = section.settings[button_background_key]
          assign slide_button_text_color = section.settings[button_text_color_key]
          assign slide_text_color = section.settings[text_color_key]
          assign slide_overlay_color = section.settings[overlay_color_key]
          assign slide_overlay_opacity = section.settings[overlay_opacity_key]
        -%}

        <div class="image-overlay-slider__slide-{{ section.id }}">
          <style>
            #shopify-section-{{ section.id }} {
              --slide-overlay-{{ i }}: {{ slide_overlay_color.rgb }} / {{ slide_overlay_opacity | divided_by: 100.0 }};
            }
          </style>

          <image-banner reveal-on-scroll="true" {% if section.settings.enable_parallax %}parallax="0.3"{% endif %} {% render 'surface', class: class, text_color: slide_text_color %}>
            {%- if slide_image != blank -%}
              {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}(max-width: 740px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){% endif %}{%- endcapture -%}
              {%- capture fetch_priority -%}{% if section.index == 1 and forloop.first %}high{% else %}low{% endif %}{%- endcapture -%}

              <picture>
                {%- if slide_mobile_image != blank -%}
                  <source
                    media="(max-width: 699px)"
                    srcset="{{ slide_mobile_image | image_url: width: '400x' }} 400w, {{ slide_mobile_image | image_url: width: '600x' }} 600w, {{ slide_mobile_image | image_url: width: '800x' }} 800w, {{ slide_mobile_image | image_url: width: '1000x' }} 1000w, {{ slide_mobile_image | image_url: width: '1200x' }} 1200w"
                    width="{{ slide_mobile_image.width }}"
                    height="{{ slide_mobile_image.height }}"
                  >
                {%- endif -%}

                {{- slide_image | image_url: width: slide_image.width | image_tag: sizes: sizes, fetchpriority: fetch_priority, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
              </picture>
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
            {%- endif -%}

            <div class="{{ section.settings.mobile_text_position }} {{ section.settings.desktop_text_position }}">
              <div class="prose">
                {%- if slide_subheading != blank -%}
                  <p class="bold">{{ slide_subheading | escape }}</p>
                {%- endif -%}

                {%- if slide_heading != blank -%}
                  <p class="{{ slide_heading_tag }}" {% if settings.heading_apparition != 'none' %}reveal-on-scroll="true"{% endif %}>
                    {%- render 'styled-text', content: slide_heading, apparition_effect: true -%}
                  </p>
                {%- endif -%}

                {%- if slide_content != blank -%}
                  <div>
                    {{- slide_content -}}
                  </div>
                {%- endif -%}

                {%- if slide_button_text != blank -%}
                  {% render 'button',
                    content: slide_button_text,
                    href: slide_button_url,
                    size: slide_button_size,
                    style: slide_button_style,
                    background: slide_button_background,
                    text_color: slide_button_text_color
                  %}
                {%- endif -%}
              </div>
            </div>
          </image-banner>
        </div>
      {%- endfor -%}
    </div>

    <button class="image-overlay-slider__arrow-{{ section.id }} image-overlay-slider__arrow--prev-{{ section.id }}" type="button" aria-label="Previous slide">‹</button>
    <button class="image-overlay-slider__arrow-{{ section.id }} image-overlay-slider__arrow--next-{{ section.id }}" type="button" aria-label="Next slide">›</button>

    <div class="image-overlay-slider__nav-{{ section.id }}">
      <button class="image-overlay-slider__dot-{{ section.id }} is-active" type="button" aria-label="Slide 1"></button>
      <button class="image-overlay-slider__dot-{{ section.id }}" type="button" aria-label="Slide 2"></button>
      <button class="image-overlay-slider__dot-{{ section.id }}" type="button" aria-label="Slide 3"></button>
    </div>
  </div>
</div>

<script>
  (() => {
    const slider = document.getElementById('image-overlay-slider-{{ section.id }}');
    if (!slider) return;

    const track = slider.querySelector('.image-overlay-slider__track-{{ section.id }}');
    const slides = slider.querySelectorAll('.image-overlay-slider__slide-{{ section.id }}');
    const dots = slider.querySelectorAll('.image-overlay-slider__dot-{{ section.id }}');
    const prevBtn = slider.querySelector('.image-overlay-slider__arrow--prev-{{ section.id }}');
    const nextBtn = slider.querySelector('.image-overlay-slider__arrow--next-{{ section.id }}');

    let currentIndex = 0;
    let autoplay = null;
    const delay = {{ section.settings.autoplay_speed | times: 1000 }};

    function goToSlide(index) {
      currentIndex = index;
      track.style.transform = 'translateX(-' + (currentIndex * 100) + '%)';

      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === currentIndex);
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % slides.length;
      goToSlide(currentIndex);
    }

    function prevSlide() {
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      goToSlide(currentIndex);
    }

    function startAutoplay() {
      stopAutoplay();
      autoplay = setInterval(nextSlide, delay);
    }

    function stopAutoplay() {
      if (autoplay) {
        clearInterval(autoplay);
        autoplay = null;
      }
    }

    nextBtn.addEventListener('click', () => {
      nextSlide();
      startAutoplay();
    });

    prevBtn.addEventListener('click', () => {
      prevSlide();
      startAutoplay();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        goToSlide(index);
        startAutoplay();
      });
    });

    slider.addEventListener('mouseenter', stopAutoplay);
    slider.addEventListener('mouseleave', startAutoplay);

    goToSlide(0);
    startAutoplay();
  })();
</script>

