{%- unless section.settings.full_width -%}
  {%- render 'section-spacing-collapsing' -%}
{%- endunless -%}

<style>
  #shopify-section-{{ section.id }} {
    {%- if section.settings.full_width -%}
      --section-outer-spacing-block: 0;
    {%- endif -%}

    {%- if section.settings.allow_transparent_header -%}
      margin-block-start: calc(-1 * var(--header-height) * var(--section-is-first));
    {%- endif -%}
  }

  .custom-slideshow {
    position: relative;
    overflow: hidden;
  }

  .custom-slideshow__track {
    display: flex;
    transition: transform 0.6s ease;
    will-change: transform;
  }

  .custom-slideshow__slide {
    min-width: 100%;
    position: relative;
  }

  .custom-slideshow__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .custom-slideshow__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    padding: 1.5rem;
  }

  .custom-slideshow__nav {
    position: absolute;
    z-index: 3;
    inset-inline: 0;
    bottom: 18px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .custom-slideshow__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    opacity: 0.5;
    background: white;
  }

  .custom-slideshow__dot.is-active {
    opacity: 1;
  }

  .custom-slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    border: none;
    cursor: pointer;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: rgb(0 0 0 / 0.35);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-slideshow__arrow--prev {
    left: 16px;
  }

  .custom-slideshow__arrow--next {
    right: 16px;
  }

  @media screen and (max-width: 699px) {
    .custom-slideshow__arrow {
      width: 36px;
      height: 36px;
    }
  }
</style>

<div {% render 'section-properties' %} {% if section.settings.allow_transparent_header %}allow-transparent-header{% endif %}>
  {%- capture class -%}
    content-over-media content-over-media--{{ section.settings.image_size }} {% if section.settings.full_width %}full-bleed{% else %}shadow-block rounded-lg{% endif %}
  {%- endcapture -%}

  <div class="custom-slideshow {% if section.settings.full_width %}full-bleed{% else %}shadow-block rounded-lg{% endif %}" id="slideshow-{{ section.id }}">
    <div class="custom-slideshow__track">
      {%- for block in section.blocks limit: 3 -%}
        <div class="custom-slideshow__slide" {{ block.shopify_attributes }}>
          <image-banner
            reveal-on-scroll="true"
            {% if section.settings.enable_parallax %}parallax="0.3"{% endif %}
            {% render 'surface', class: class, text_color: block.settings.text_color %}
          >
            {%- if block.settings.image != blank -%}
              {%- capture sizes -%}
                {% if section.settings.full_width %}
                  100vw
                {% else %}
                  (max-width: 740px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px)
                {% endif %}
              {%- endcapture -%}

              {%- capture fetch_priority -%}
                {% if section.index == 1 and forloop.first %}high{% else %}low{% endif %}
              {%- endcapture -%}

              <picture>
                {%- if block.settings.mobile_image != blank -%}
                  <source
                    media="(max-width: 699px)"
                    srcset="{{ block.settings.mobile_image | image_url: width: '400x' }} 400w, {{ block.settings.mobile_image | image_url: width: '600x' }} 600w, {{ block.settings.mobile_image | image_url: width: '800x' }} 800w, {{ block.settings.mobile_image | image_url: width: '1000x' }} 1000w, {{ block.settings.mobile_image | image_url: width: '1200x' }} 1200w"
                    width="{{ block.settings.mobile_image.width }}"
                    height="{{ block.settings.mobile_image.height }}"
                  >
                {%- endif -%}

                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: sizes, fetchpriority: fetch_priority, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
              </picture>
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
            {%- endif -%}

            <div
              class="custom-slideshow__overlay"
              style="background: rgb({{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }});"
            ></div>

            <div class="custom-slideshow__content {{ section.settings.mobile_text_position }} {{ section.settings.desktop_text_position }}">
              <div class="prose" style="color: {{ block.settings.text_color }};">
                {%- if block.settings.subheading != blank -%}
                  <p class="bold">{{ block.settings.subheading | escape }}</p>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <p class="{{ block.settings.heading_tag }}">
                    {%- render 'styled-text', content: block.settings.heading, apparition_effect: true -%}
                  </p>
                {%- endif -%}

                {%- if block.settings.content != blank -%}
                  <div>{{ block.settings.content }}</div>
                {%- endif -%}

                {%- if block.settings.button_text != blank -%}
                  {% render 'button',
                    content: block.settings.button_text,
                    href: block.settings.button_url,
                    size: block.settings.button_size,
                    style: block.settings.button_style,
                    background: block.settings.button_background,
                    text_color: block.settings.button_text_color
                  %}
                {%- endif -%}
              </div>
            </div>
          </image-banner>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="custom-slideshow__arrow custom-slideshow__arrow--prev" aria-label="Previous slide" type="button">‹</button>
      <button class="custom-slideshow__arrow custom-slideshow__arrow--next" aria-label="Next slide" type="button">›</button>

      <div class="custom-slideshow__nav">
        {%- for block in section.blocks limit: 3 -%}
          <button class="custom-slideshow__dot {% if forloop.first %}is-active{% endif %}" type="button" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (() => {
    const root = document.getElementById('slideshow-{{ section.id }}');
    if (!root) return;

    const track = root.querySelector('.custom-slideshow__track');
    const slides = Array.from(root.querySelectorAll('.custom-slideshow__slide'));
    const dots = Array.from(root.querySelectorAll('.custom-slideshow__dot'));
    const prev = root.querySelector('.custom-slideshow__arrow--prev');
    const next = root.querySelector('.custom-slideshow__arrow--next');

    if (slides.length <= 1) return;

    let index = 0;
    let interval;

    function updateSlider() {
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function goToSlide(newIndex) {
      index = (newIndex + slides.length) % slides.length;
      updateSlider();
    }

    function startAutoPlay() {
      interval = setInterval(() => {
        goToSlide(index + 1);
      }, 5000);
    }

    function stopAutoPlay() {
      clearInterval(interval);
    }

    if (prev) {
      prev.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(index - 1);
        startAutoPlay();
      });
    }

    if (next) {
      next.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(index + 1);
        startAutoPlay();
      });
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(i);
        startAutoPlay();
      });
    });

    root.addEventListener('mouseenter', stopAutoPlay);
    root.addEventListener('mouseleave', startAutoPlay);

    updateSlider();
    startAutoPlay();
  })();
</script>

