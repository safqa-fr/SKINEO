      "blocks": {
        "tab_GBQzNE": {
          "type": "tab",
          "settings": {
            "title": "White Rice or Black Rice?",
            "content": "<ul><li><strong>White Rice</strong><br/>For sensitive, normal, or dry skin.<br/>Gentle, hydrating exfoliation that delivers instant glow, refines skin texture, boosts hydration, and is safe for sensitive skin.<br/><strong>Use:</strong> 2–3 times per week.</li><li><strong>Black Rice</strong><br/>For oily, combination, or blemish-prone skin.<br/>Intensive, purifying exfoliation that deeply cleans pores, helps reduce blackheads, controls excess oil, and minimizes the look of enlarged pores.<br/><strong>Use:</strong> 1–2 times per week (focus on problem areas).</li><li><strong>Our tip:</strong><br/>Not sure which one to choose? Start with <strong>White Rice</strong> for sensitive or normal skin. Choose <strong>Black Rice</strong> if you struggle with enlarged pores or excess oil. You can also alternate between both depending on your skin’s needs.</li></ul><p><strong>Recommended use:</strong> 2–3 times per week</p><p><em>Our Recommendation<br/>Not sure which one to choose?<br/>Start with </em><em><strong>White Rice</strong></em><em> if you have sensitive or normal skin.<br/>Choose </em><em><strong>Black Rice</strong></em><em> if you’re dealing with enlarged pores or excess oil.<br/></em><em><strong>Pro tip:</strong></em><em> You can also alternate between the two depending on your skin’s needs!</em></p>",
            "page": ""
          }
        },
        "tab_D4FYVk": {
          "type": "tab",
          "settings": {
            "title": "Try it risk-free for 30 days",
            "content": "<p>If you are not satisfied, you may return your <strong>Peel Shot within 30 days</strong>, provided the product is <strong>unopened and unused</strong>.<br/>Due to hygiene reasons, <strong>opened products are not eligible for refunds</strong>.</p>",
            "page": ""
          }
        },
        "tab_cqnERK": {
          "type": "tab",
          "settings": {
            "title": "Free Delivery to Your Door",
            "content": "<p><strong>Free home delivery is included. </strong>Depending on the volume of orders being processed, delivery is estimated between <strong>5 and 12 business days</strong>.</p>",
            "page": ""
          }
        },
        "tab_3GDbNg": {
          "type": "tab",
          "settings": {
            "title": "7-day customer support",
            "content": "<p>Our team is available to answer your questions seven days a week.</p><p>You can contact us by email during the following hours: <strong>Monday to Friday from 9:00 a.m. to 12:00 p.m. and from 2:00 p.m. to 6:00 p.m., and Saturday and Sunday from 10:00 a.m. to 12:00 p.m. </strong></p><p>Feel free to get in touch with us.</p>",
            "page": ""
          }
